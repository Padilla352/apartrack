{
  "build": {
    "nixpacks": {
      "phases": {
        "setup": {
          "nixPkgs": ["php83", "composer", "nodejs_20"]
        },
        "install": {
          "cmds": ["composer install --no-dev --optimize-autoloader", "npm ci --production=false"]
        },
        "build": {
          "cmds": ["npm run build"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "php artisan migrate --force && php artisan serve --host=0.0.0.0 --port=8080"
  }
}